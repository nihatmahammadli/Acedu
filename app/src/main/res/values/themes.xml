<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Acedu" parent="Theme.AppCompat.DayNight.NoActionBar">
        <!-- Pəncərənin fonu bizim DeepNavy rəngimiz olacaq -->
        <item name="android:windowBackground">@color/acedu_bg</item>
        <item name="android:statusBarColor">@color/acedu_bg</item>
        <item name="android:navigationBarColor">@color/acedu_bg</item>

        <!-- Android 12+ Splash ləğvi/uyğunlaşdırılması üçün -->
        <item name="android:windowSplashScreenBackground" tools:targetApi="31">@color/acedu_bg</item>
        <item name="android:windowSplashScreenAnimatedIcon" tools:targetApi="31">@android:color/transparent</item>
    </style>
</resources>